<Window
    x:Class="FufuLauncher.Views.ScreenshotGalleryWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:FufuLauncher.Models"
    mc:Ignorable="d"
    Title="截图图库">

    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid x:Name="RootGrid">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" x:Name="AppTitleBarRow" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid.Resources>
            <CollectionViewSource x:Name="GalleryViewSource" IsSourceGrouped="True" ItemsPath="Items" />
        </Grid.Resources>

        <GridView x:Name="GalleryGridView" 
                  Grid.Row="1"
                  ItemsSource="{Binding Source={StaticResource GalleryViewSource}}"
                  SelectionMode="None"
                  IsItemClickEnabled="True"
                  ItemClick="GalleryGridView_ItemClick"
                  Padding="24">
            
            <GridView.GroupStyle>
                <GroupStyle>
                    <GroupStyle.HeaderContainerStyle>
                        <Style TargetType="GridViewHeaderItem">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="GridViewHeaderItem">
                                        <ContentPresenter Content="{TemplateBinding Content}"
                                                          ContentTemplate="{TemplateBinding ContentTemplate}"
                                                          Margin="0,16,0,8"/>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </GroupStyle.HeaderContainerStyle>
                    <GroupStyle.HeaderTemplate>
                        <DataTemplate x:DataType="models:ScreenshotGroup">
                            <TextBlock Text="{x:Bind DateKey}" 
                                       FontSize="20" 
                                       FontWeight="SemiBold"/>
                        </DataTemplate>
                    </GroupStyle.HeaderTemplate>
                </GroupStyle>
            </GridView.GroupStyle>

            <GridView.ItemTemplate>
                <DataTemplate x:DataType="models:ScreenshotItem">
                    <Grid x:Name="ItemGrid" Width="160" Height="160" Margin="4"
                          PointerEntered="GridItem_PointerEntered"
                          PointerExited="GridItem_PointerExited"
                          CornerRadius="8"
                          Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                          RenderTransformOrigin="0.5,0.5">
                        <Grid.RenderTransform>
                            <ScaleTransform x:Name="ItemScale" ScaleX="1" ScaleY="1" />
                        </Grid.RenderTransform>
                        <Image x:Name="GridImage" Source="{x:Bind ImageSource}" Stretch="UniformToFill" />
                    </Grid>
                </DataTemplate>
            </GridView.ItemTemplate>
        </GridView>

        <Grid x:Name="DetailOverlayGrid" Grid.Row="1" Visibility="Collapsed" Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <CommandBar Grid.Row="0" DefaultLabelPosition="Right" Padding="12,0,12,0">
                <CommandBar.PrimaryCommands>
                    <AppBarButton Icon="Back" Label="返回相册" Click="CloseDetailView_Click" />
                    <AppBarSeparator />
                    <AppBarButton Icon="Copy" Label="复制" Click="CopyImage_Click" />
                    <AppBarButton Icon="Cut" Label="剪切" Click="CutImage_Click" />
                    <AppBarButton Icon="Delete" Label="删除" Click="DeleteImage_Click" />
                    <AppBarSeparator />
                    <AppBarButton Icon="OpenFile" Label="使用系统应用打开" Click="OpenWithSystemApp_Click" />
                </CommandBar.PrimaryCommands>
            </CommandBar>

            <ScrollViewer Grid.Row="1" 
                          x:Name="DetailScrollViewer"
                          ZoomMode="Enabled" 
                          MinZoomFactor="0.1" 
                          MaxZoomFactor="10.0"
                          HorizontalScrollMode="Auto" 
                          VerticalScrollMode="Auto"
                          HorizontalScrollBarVisibility="Auto" 
                          VerticalScrollBarVisibility="Auto"
                          PointerWheelChanged="DetailScrollViewer_PointerWheelChanged">
                <Image x:Name="DetailImageViewer" Stretch="Uniform" Opacity="1" RenderTransformOrigin="0.5,0.5"/>
            </ScrollViewer>
        </Grid>
    </Grid>
</Window>