<Window
    x:Class="FufuLauncher.Views.UpdateWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="FufuLauncher 更新">

    <Grid Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
        <WebView2 x:Name="MiniWebView" Width="1" Height="1" Opacity="0.01" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="0" />
        
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="24" Margin="32,40,32,32">
            
            <TextBlock Text="FufuLauncher 更新中心" FontSize="22" FontWeight="SemiBold" HorizontalAlignment="Center"/>
            
            <InfoBar x:Name="ErrorInfoBar" IsOpen="False" Severity="Error" Title="发生异常" MaxWidth="350" />

            <StackPanel x:Name="LoadingPanel" Spacing="16" HorizontalAlignment="Center">
                <ProgressRing x:Name="StatusRing" IsActive="True" Width="36" Height="36" HorizontalAlignment="Center"/>
                <TextBlock x:Name="StatusTextBlock" Text="正在解析地址..." Foreground="{ThemeResource TextFillColorSecondaryBrush}" HorizontalAlignment="Center" />
            </StackPanel>

            <StackPanel x:Name="DownloadPanel" Spacing="12" Visibility="Collapsed" Width="320">
                <TextBlock x:Name="DownloadStatusTextBlock" Text="准备下载..." HorizontalAlignment="Left" FontWeight="Medium" TextTrimming="CharacterEllipsis"/>
                <ProgressBar x:Name="DownloadProgressBar" Minimum="0" Maximum="100" Value="0" Height="6" CornerRadius="3" />
                <TextBlock x:Name="ProgressTextBlock" Text="0.0% (0 MB / 0 MB)" HorizontalAlignment="Right" Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="12" />
            </StackPanel>
            
        </StackPanel>
    </Grid>
</Window>